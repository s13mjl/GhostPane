<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ===== 颜色（苹果风） ===== -->
    <Color x:Key="AppleBackgroundColor">#F5F5F7</Color>
    <Color x:Key="AppleSurfaceColor">#FFFFFF</Color>
    <Color x:Key="AppleSidebarColor">#FAFAFC</Color>
    <Color x:Key="AppleTextPrimaryColor">#1D1D1F</Color>
    <Color x:Key="AppleTextSecondaryColor">#86868B</Color>
    <Color x:Key="AppleBorderColor">#E5E5EA</Color>
    <Color x:Key="AppleAccentColor">#007AFF</Color>
    <Color x:Key="AppleAccentHoverColor">#0A84FF</Color>
    <Color x:Key="AppleSuccessColor">#34C759</Color>
    <Color x:Key="AppleWarningColor">#FF9500</Color>
    <Color x:Key="AppleDangerColor">#FF3B30</Color>
    <Color x:Key="AppleHoverColor">#F2F2F7</Color>
    <Color x:Key="AppleSelectedColor">#E3F0FF</Color>

    <SolidColorBrush x:Key="AppleBackgroundBrush" Color="{StaticResource AppleBackgroundColor}"/>
    <SolidColorBrush x:Key="AppleSurfaceBrush" Color="{StaticResource AppleSurfaceColor}"/>
    <SolidColorBrush x:Key="AppleSidebarBrush" Color="{StaticResource AppleSidebarColor}"/>
    <SolidColorBrush x:Key="AppleTextPrimaryBrush" Color="{StaticResource AppleTextPrimaryColor}"/>
    <SolidColorBrush x:Key="AppleTextSecondaryBrush" Color="{StaticResource AppleTextSecondaryColor}"/>
    <SolidColorBrush x:Key="AppleBorderBrush" Color="{StaticResource AppleBorderColor}"/>
    <SolidColorBrush x:Key="AppleAccentBrush" Color="{StaticResource AppleAccentColor}"/>
    <SolidColorBrush x:Key="AppleAccentHoverBrush" Color="{StaticResource AppleAccentHoverColor}"/>
    <SolidColorBrush x:Key="AppleSuccessBrush" Color="{StaticResource AppleSuccessColor}"/>
    <SolidColorBrush x:Key="AppleWarningBrush" Color="{StaticResource AppleWarningColor}"/>
    <SolidColorBrush x:Key="AppleDangerBrush" Color="{StaticResource AppleDangerColor}"/>
    <SolidColorBrush x:Key="AppleHoverBrush" Color="{StaticResource AppleHoverColor}"/>
    <SolidColorBrush x:Key="AppleSelectedBrush" Color="{StaticResource AppleSelectedColor}"/>

    <sys:Double x:Key="AppleCornerRadius">8</sys:Double>

    <!-- ===== 全局字体 ===== -->
    <FontFamily x:Key="AppleFontFamily">Segoe UI Variable, Segoe UI, Microsoft YaHei UI</FontFamily>

    <!-- ===== 按钮样式（苹果风） ===== -->
    <Style x:Key="AppleButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource AppleSurfaceBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource AppleTextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource AppleBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontFamily" Value="{StaticResource AppleFontFamily}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Padding" Value="16,7"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource AppleHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource AppleBorderBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== 主按钮（强调色） ===== -->
    <Style x:Key="ApplePrimaryButton" TargetType="Button" BasedOn="{StaticResource AppleButton}">
        <Setter Property="Background" Value="{StaticResource AppleAccentBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderBrush" Value="{StaticResource AppleAccentBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource AppleAccentHoverBrush}"/>
                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AppleAccentHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#0056B3"/>
                            <Setter TargetName="border" Property="BorderBrush" Value="#0056B3"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== 危险按钮（红色） ===== -->
    <Style x:Key="AppleDangerButton" TargetType="Button" BasedOn="{StaticResource AppleButton}">
        <Setter Property="Background" Value="{StaticResource AppleSurfaceBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource AppleDangerBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource AppleDangerBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#FFE5E5"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== 列表项样式 ===== -->
    <Style x:Key="AppleListBoxItem" TargetType="ListBoxItem">
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="Margin" Value="0,1"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}"
                            Margin="{TemplateBinding Margin}">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource AppleHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource AppleSelectedBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="AppleListBox" TargetType="ListBox">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="ItemContainerStyle" Value="{StaticResource AppleListBoxItem}"/>
    </Style>

</ResourceDictionary>
